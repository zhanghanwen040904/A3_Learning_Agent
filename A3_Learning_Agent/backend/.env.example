MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=a3_learning_agent
MYSQL_CHARSET=utf8mb4

APP_HOST=0.0.0.0
APP_PORT=5000
APP_DEBUG=true
FLASK_ENV=development

MOCK_AI=false
# 默认关闭启动期数据库结构检查，避免后端一启动就检索/迁移 SQL 表。
# 需要自动建表或补字段时，临时改成 true 后启动一次。
AUTO_MIGRATE=false
# 默认关闭启动期知识库 bootstrap，避免启动时触发向量模型/embedding 加载。
AUTO_BOOTSTRAP_KNOWLEDGE=false
JWT_SECRET_KEY=replace_with_a_strong_secret_key
JWT_EXPIRE_HOURS=24

RAG_COLLECTION_NAME=software_engineering_knowledge
GENERATED_KNOWLEDGE_DIR=D:\A3_Learning_Agent\rag_data\generated_knowledge\batch_outputs_llm_vision

# Switch provider: spark | bailian | anthropic | settings | claude
AI_PROVIDER=spark
AI_MAX_INPUT_CHARS=24000
AI_MAX_TOKENS=4096

# iFlytek Spark Ultra-32K HTTP Chat Completions
# When AI_PROVIDER=spark, the backend will use these values.
SPARK_APIPASSWORD=your_spark_apipassword
SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v1/chat/completions
SPARK_MODEL=4.0Ultra

# Alibaba Cloud Bailian / DashScope (OpenAI-compatible)
# When AI_PROVIDER=bailian, the backend will use these values.
BAILIAN_API_KEY=your_bailian_api_key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
BAILIAN_MODEL=qwen-plus
